diff --git a/net/bridge/br_netfilter_hooks.c b/net/bridge/br_netfilter_hooks.c
index ee8b8d60..cb27d3dd 100644
--- a/net/bridge/br_netfilter_hooks.c
+++ b/net/bridge/br_netfilter_hooks.c
@@ -44,6 +44,10 @@
 #include <linux/sysctl.h>
 #endif
 
+#if IS_ENABLED(CONFIG_NF_CONNTRACK)
+#include <net/netfilter/nf_conntrack_core.h>
+#endif
+
 #ifdef CONFIG_SYSCTL
 static struct ctl_table_header *brnf_sysctl_header;
 static int brnf_call_iptables __read_mostly = 1;
@@ -889,6 +893,45 @@ EXPORT_SYMBOL_GPL(br_netfilter_enable);
 
 /* For br_nf_post_routing, we need (prio = NF_BR_PRI_LAST), because
  * br_dev_queue_push_xmit is called afterwards */
+#if IS_ENABLED(CONFIG_NF_CONNTRACK)
+static unsigned int br_nf_local_in(void *priv,
+				   struct sk_buff *skb,
+				   const struct nf_hook_state *state)
+{
+	enum ip_conntrack_info ctinfo;
+	struct nf_conn *ct;
+	int ret;
+
+	/* Accept host-type packets (delivered to local stack) */
+	if (skb->pkt_type == PACKET_HOST)
+		return NF_ACCEPT;
+
+	/* Try to get conntrack for this skb (compatible with older kernels) */
+	ct = nf_ct_get(skb, &ctinfo);
+	if (!ct || nf_ct_is_confirmed(ct) || nf_ct_is_template(ct))
+		return NF_ACCEPT;
+
+	/* If skb is shared, clones may interfere with confirm */
+	WARN_ON_ONCE(skb_shared(skb));
+	/* Older kernels may not have refcount_read; skip strict use-count check */
+
+	/* Directly call nf_conntrack_confirm (available in 4.4) */
+	ret = nf_conntrack_confirm(skb);
+	switch (ret & NF_VERDICT_MASK) {
+	case NF_STOLEN:
+		return NF_STOLEN;
+	default:
+		break;
+	}
+
+	/* Re-read conntrack from skb after confirm to ensure we have up-to-date pointer */
+	ct = nf_ct_get(skb, &ctinfo);
+	WARN_ON_ONCE(!ct || !nf_ct_is_confirmed(ct));
+
+	return ret;
+}
+#endif
+
 static struct nf_hook_ops br_nf_ops[] __read_mostly = {
 	{
 		.hook = br_nf_pre_routing,
