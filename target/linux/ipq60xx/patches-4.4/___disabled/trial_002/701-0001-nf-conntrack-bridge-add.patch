--- a/net/bridge/netfilter/nf_conntrack_bridge.c
+++ b/net/bridge/netfilter/nf_conntrack_bridge.c
@@ -0,0 +1,34 @@
+/*
+ * Backport: nf_conntrack bridge helper for 4.4
+ * Purpose: provide a small hook to confirm conntrack for bridged packets
+ * when necessary to avoid clones/unconfirmed conntrack races.
+ *
+ * Note: uses 4.4-compatible nf_ct_get / nf_conntrack_confirm.
+ */
+
+#include <linux/skbuff.h>
+#include <linux/netfilter.h>
+#include <net/netfilter/nf_conntrack.h>
+#include <net/netfilter/nf_conntrack_core.h>
+#include <linux/if_bridge.h>
+
+static unsigned int nf_ct_bridge_in(void *priv, struct sk_buff *skb,
+                                    const struct nf_hook_state *state)
+{
+    enum ip_conntrack_info ctinfo;
+    struct nf_conn *ct;
+
+    /* If packet is destined to local stack, skip */
+    if (skb->pkt_type == PACKET_HOST)
+        return NF_ACCEPT;
+
+    /* Get conntrack associated with skb (4.4 API) */
+    ct = nf_ct_get(skb, &ctinfo);
+    if (!ct || nf_ct_is_confirmed(ct) || nf_ct_is_template(ct))
+        return NF_ACCEPT;
+
+    /*
+     * Try to confirm the conntrack for this skb.
+     */
+    return nf_conntrack_confirm(skb);
+}
